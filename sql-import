# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ TOOLS в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

do_list_backups() {
    print_header
    echo -e "${BOLD}${BLUE}  Alle Backups${NC}"
    echo "  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"
    echo ""

    local UP=$'\x1b[A'
    local DOWN=$'\x1b[B'
    local ESC=$'\x1b'
    local files=()
    while IFS= read -r -d '' f; do
        files+=("$f")
    done < <(find "$BACKUP_DIR" -maxdepth 1 -name '*.sql' -type f -print0 2>/dev/null | sort -z)

    if [ ${#files[@]} -eq 0 ]; then
        echo -e "  ${YELLOW}Keine Backups gefunden.${NC}"
    else
        local page=0
        local per_page=10

        while true; do
            print_header
            echo -e "${BOLD}${BLUE}  Alle Backups${NC}"
            echo "  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"
            echo -e "  ${YELLOW}Pfeile вҶ‘вҶ“ blГӨttern, ESC zurГјck${NC}"
            echo ""

            start=$((page * per_page))
            end=$((start + per_page))
            [ $end -gt ${#files[@]} ] && end=${#files[@]}

            for i in $(seq $start $((end - 1))); do
                local f="${files[$i]}"
                local fname=$(basename "$f")
                local fsize=$(numfmt --to=iec --format="%.1f" "$(stat -c%s "$f")" 2>/dev/null)
                local fdate=$(stat -c%y "$f" 2>/dev/null | cut -d. -f1)
                echo -e "  ${fname}"
                echo -e "    ${CYAN}GrГ¶Гҹe:${NC} $fsize  ${CYAN}Datum:${NC} $fdate"
                echo ""
            done

            local total_pages=$(((${#files[@]} + per_page - 1) / per_page))
            echo -e "  ${YELLOW}Seite $((page + 1))/$total_pages  (${#files[@]} Backups)${NC}"

            local key
            key=$(read_key)
            case "$key" in
                "$UP") [ $page -gt 0 ] && page=$((page - 1)) ;;
                "$DOWN") [ $page -lt $((total_pages - 1)) ] && page=$((page + 1)) ;;
                ""|$'\n'|$'\r'|$ESC) break ;;
            esac
        done
    fi

    echo -e "\n  ${YELLOW}Enter fГјr MenГј...${NC}"
    read -r
}

