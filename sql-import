#!/usr/bin/env bash
set +e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'
BOLD='\033[1m'
INV='\033[7m'

DB_USER="root"
DB_PASS="root"
BACKUP_DIR="$HOME/mariadb-backups"
mkdir -p "$BACKUP_DIR"

ABORT_FLAG=0
abort_handler() {
    ABORT_FLAG=1
    echo ""
    echo -e "  ${YELLOW}⚠ Abbruch angefordert...${NC}"
}
trap abort_handler SIGINT

read_key() {
    local k
    IFS= read -r -s -n1 k 2>/dev/null
    if [[ $k == $'\x1b' ]]; then
        local rest
        IFS= read -r -s -n2 -t 0.1 rest 2>/dev/null
        k="${k}${rest}"
    fi
    printf '%s' "$k"
}

print_header() {
    printf '\033[2J\033[H'
    echo -e "${CYAN}${BOLD}┌─────────────────────────────────────────────┐${NC}"
    echo -e "${CYAN}${BOLD}│       SMARTBOXX SQL TOOL  v1.1              │${NC}"
    echo -e "${CYAN}${BOLD}│          $(date '+%d.%m.%Y %H:%M')                   │${NC}"
    echo -e "${CYAN}${BOLD}└─────────────────────────────────────────────┘${NC}"
    echo ""
}

print_info_bar() {
    BACKUP_COUNT=$(find "$BACKUP_DIR" -maxdepth 1 -type f -name "*.sql" 2>/dev/null | wc -l)
    echo -e "  ${BOLD}User:${NC} ${GREEN}$DB_USER${NC}  ${BOLD}Backups:${NC} ${GREEN}$BACKUP_COUNT${NC}"
    if command -v pv &>/dev/null; then
        echo -e "  ${GREEN}✓${NC} pv installiert"
    else
        echo -e "  ${YELLOW}⚠${NC} pv fehlt"
    fi
    echo ""
}

menu_select() {
    local title="$1"
    shift
    local items=("$@")
    local selected=0
    local UP=$'\x1b[A'
    local DOWN=$'\x1b[B'

    while true; do
        print_header
        echo -e "  ${BOLD}${BLUE}$title${NC}"
        echo "  ─────────────────────────────"
        echo ""

        for i in "${!items[@]}"; do
            if [ $i -eq $selected ]; then
                echo -e "  ${INV}${CYAN}  ${items[$i]}  ${NC}"
            else
                echo -e "  ${WHITE}  ${items[$i]}${NC}"
            fi
        done

        echo ""
        echo -e "  ${YELLOW}Pfeile ↑↓ bewegen, Enter wählen, ESC zurück${NC}"

        local key
        key=$(read_key)

        case "$key" in
            "$UP")
                selected=$((selected - 1))
                [ $selected -lt 0 ] && selected=$((${#items[@]} - 1))
                ;;
            "$DOWN")
                selected=$((selected + 1))
                [ $selected -ge ${#items[@]} ] && selected=0
                ;;
            ""|$'\n'|$'\r')
                return $selected
                ;;
            $'\x1b')
                return 255
                ;;
        esac
    done
}

file_browser() {
    local start_dir="${1:-$HOME}"
    local current_dir="$start_dir"
    local selected=0
    local UP=$'\x1b[A'
    local DOWN=$'\x1b[B'

    while true; do
        local items=()
        local types=()
        local dirs=()
        local files=()

        if [ "$current_dir" != "/" ]; then
            dirs+=("..")
        fi

        while IFS= read -r -d '' d; do
            local base
            base=$(basename "$d")
            dirs+=("$base")
        done < <(find "$current_dir" -maxdepth 1 -type d ! -name "$(basename "$current_dir")" -print0 2>/dev/null | sort -z)

        while IFS= read -r -d '' f; do
            local base
            base=$(basename "$f")
            files+=("$base")
        done < <(find "$current_dir" -maxdepth 1 -type f -name "*.sql" -print0 2>/dev/null | sort -z)

        for d in "${dirs[@]}"; do
            items+=("$d")
            types+=("dir")
        done
        for f in "${files[@]}"; do
            items+=("$f")
            types+=("file")
        done

        if [ $selected -ge ${#items[@]} ]; then
            selected=0
        fi

        while true; do
            print_header
            echo -e "${BOLD}${BLUE}  Datei-Auswahl${NC}"
            echo "  ─────────────────────────────"
            echo ""
            echo -e "  ${CYAN}$current_dir${NC}"
            echo ""

            if [ ${#items[@]} -eq 0 ]; then
                echo "  (leer)"
            else
                for i in "${!items[@]}"; do
                    local prefix="  "
                    local color="$WHITE"
                    local suffix=""
                    if [ $i -eq $selected ]; then
                        prefix="${INV} "
                        color="$CYAN"
                    fi
                    if [ "${types[$i]}" = "dir" ]; then
                        suffix="/"
                        [ $i -eq $selected ] && color="${CYAN}" || color="${GREEN}"
                    else
                        local fsize
                        fsize=$(numfmt --to=iec --format="%.1f" "$(stat -c%s "$current_dir/${items[$i]}" 2>/dev/null)" 2>/dev/null)
                        suffix="  ${YELLOW}(${fsize})${NC}"
                        [ $i -eq $selected ] && color="${CYAN}" || color="${YELLOW}"
                    fi
                    if [ $i -eq $selected ]; then
                        echo -e "${INV} ${color} ${items[$i]}${suffix}  ${NC}"
                    else
                        echo -e "  ${color} ${items[$i]}${suffix}${NC}"
                    fi
                done
            fi

            echo ""
            echo -e "  ${YELLOW}Pfeile ↑↓ bewegen, Enter wählen, ESC zurück${NC}"

            local key
            key=$(read_key)

            case "$key" in
                "$UP")
                    selected=$((selected - 1))
                    [ $selected -lt 0 ] && selected=$((${#items[@]} - 1))
                    ;;
                "$DOWN")
                    selected=$((selected + 1))
                    [ $selected -ge ${#items[@]} ] && selected=0
                    ;;
                ""|$'\n'|$'\r')
                    break
                    ;;
                $'\x1b')
                    return 1
                    ;;
            esac
        done

        if [ ${#items[@]} -eq 0 ]; then
            continue
        fi

        local idx=$selected
        local selected_item="${items[$idx]}"

        if [ "${types[$idx]}" = "dir" ]; then
            if [ "$selected_item" = ".." ]; then
                current_dir="$(dirname "$current_dir")"
            else
                current_dir="$current_dir/$selected_item"
            fi
            selected=0
        else
            SQL_FILE="$current_dir/$selected_item"
            return 0
        fi
    done
}

confirm_dialog() {
    local prompt="$1"
    local options=("JA" "NEIN")
    local selected=0
    local RIGHT=$'\x1b[C'
    local LEFT=$'\x1b[D'

    while true; do
        echo ""
        for i in "${!options[@]}"; do
            if [ $i -eq $selected ]; then
                echo -e "  ${INV}${RED}  ${options[$i]}  ${NC}"
            else
                echo -e "  ${WHITE}  ${options[$i]}${NC}"
            fi
        done
        echo ""
        echo -e "  ${YELLOW}← → wechseln, Enter bestätigen${NC}"

        local key
        key=$(read_key)
        case "$key" in
            "$RIGHT") selected=1 ;;
            "$LEFT") selected=0 ;;
            ""|$'\n'|$'\r')
                [ $selected -eq 0 ] && return 0 || return 1
                ;;
        esac
    done
}

do_import() {
    print_header
    echo -e "${BOLD}${BLUE}  SQL-Datei importieren${NC}"
    echo "  ─────────────────────────────"
    echo ""
    echo -e "  ${YELLOW}ESC = zurück, Enter = Ordner öffnen/auswählen${NC}"
    echo ""
    echo -e "  ${CYAN}Drücke Enter...${NC}"
    read -r

    if ! file_browser "$HOME/SMARTBOXX-TOOLS"; then
        return
    fi

    FILE_SIZE=$(numfmt --to=iec --format="%.1f" "$(stat -c%s "$SQL_FILE")" 2>/dev/null || echo "?")
    echo -e "  ${GREEN}✓ Ausgewählt:${NC} $SQL_FILE"
    echo -e "  ${CYAN}  Größe:${NC} $FILE_SIZE"
    echo ""
    read -p "  Name der Zieldatenbank (leer = alle): " DB_NAME

    echo ""
    echo -e "  ${YELLOW}Import starten?${NC}"

    ABORT_FLAG=0
    if confirm_dialog; then
        print_header
        echo -e "  ${YELLOW}Import läuft... Strg+C = Abbruch${NC}"
        echo ""

        START_TIME=$(date +%s)
        if [ -z "$DB_NAME" ]; then
            if command -v pv &>/dev/null; then
                pv -p "$SQL_FILE" | mariadb -u "$DB_USER" -p"$DB_PASS"
            else
                mariadb -u "$DB_USER" -p"$DB_PASS" < "$SQL_FILE"
            fi
        else
            mariadb -u "$DB_USER" -p"$DB_PASS" -e "CREATE DATABASE IF NOT EXISTS \`$DB_NAME\`;" 2>/dev/null
            if command -v pv &>/dev/null; then
                pv -p "$SQL_FILE" | mariadb -u "$DB_USER" -p"$DB_PASS" "$DB_NAME"
            else
                mariadb -u "$DB_USER" -p"$DB_PASS" "$DB_NAME" < "$SQL_FILE"
            fi
        fi

        END_TIME=$(date +%s)
        DURATION=$((END_TIME - START_TIME))
        echo ""
        if [ $ABORT_FLAG -eq 1 ]; then
            echo -e "  ${YELLOW}${BOLD}⚠ Import abgebrochen${NC}"
            ABORT_FLAG=0
        else
            echo -e "  ${GREEN}${BOLD}✓ Import abgeschlossen!${NC}"
            echo -e "  ${CYAN}  Dauer:${NC} $(printf '%02d:%02d' $((DURATION / 60)) $((DURATION % 60)))"
        fi
    else
        echo -e "\n  ${YELLOW}Import abgebrochen.${NC}"
    fi

    echo ""
    echo -e "  ${YELLOW}Enter für Menü...${NC}"
    read -r
}

do_backup() {
    print_header
    echo -e "${BOLD}${YELLOW}  Datenbank-Backup erstellen${NC}"
    echo "  ─────────────────────────────"
    echo ""

    TIMESTAMP=$(date '+%Y%m%d_%H%M%S')
    BACKUP_FILE="$BACKUP_DIR/mariadb-backup-$TIMESTAMP.sql"
    echo -e "  Ziel: ${CYAN}$BACKUP_FILE${NC}"
    echo ""

    DBS=$(mariadb -u "$DB_USER" -p"$DB_PASS" -N -e "SHOW DATABASES;" 2>/dev/null | grep -v -E "^(information_schema|performance_schema|sys)$" || true)

    if [ -z "$DBS" ]; then
        echo -e "\n  ${RED}✗ Keine Datenbanken gefunden.${NC}"
        echo -e "\n  ${YELLOW}Enter für Menü...${NC}"
        read -r; return
    fi

    echo -e "  ${GREEN}✓ Gefundene Datenbanken:${NC}"
    while IFS= read -r db; do
        echo -e "    • ${CYAN}$db${NC}"
    done <<< "$DBS"
    echo ""

    local db_list=()
    while IFS= read -r db; do
        db_list+=("$db")
    done <<< "$DBS"
    db_list+=("ALLE")

    menu_select "Datenbank auswählen:" "${db_list[@]}"
    local choice=$?

    if [ $choice -eq 255 ]; then
        return
    fi

    ABORT_FLAG=0
    if [ $choice -eq $((${#db_list[@]} - 1)) ]; then
        local EST_SIZE
        EST_SIZE=$(mariadb -u "$DB_USER" -p"$DB_PASS" -NBe \
            "SELECT SUM(data_length + index_length) FROM information_schema.tables WHERE table_schema NOT IN ('mysql','information_schema','performance_schema','sys')" 2>/dev/null || echo 0)
        [ -z "$EST_SIZE" ] && EST_SIZE=0
        echo ""
        echo -e "  ${YELLOW}Backup ALLER Datenbanken läuft... Strg+C = Abbruch${NC}"
        START_TIME=$(date +%s)
        if command -v pv &>/dev/null; then
            mariadb-dump -u "$DB_USER" -p"$DB_PASS" --databases $(echo "$DBS" | tr '\n' ' ') | pv -p -s "$EST_SIZE" > "$BACKUP_FILE"
        else
            mariadb-dump -u "$DB_USER" -p"$DB_PASS" --databases $(echo "$DBS" | tr '\n' ' ') > "$BACKUP_FILE"
        fi
    else
        local DB_SELECTED="${db_list[$choice]}"
        local EST_SIZE
        EST_SIZE=$(mariadb -u "$DB_USER" -p"$DB_PASS" -NBe \
            "SELECT SUM(data_length + index_length) FROM information_schema.tables WHERE table_schema='$DB_SELECTED'" 2>/dev/null || echo 0)
        [ -z "$EST_SIZE" ] && EST_SIZE=0
        BACKUP_FILE="$BACKUP_DIR/mariadb-backup-${DB_SELECTED}-$TIMESTAMP.sql"
        echo ""
        echo -e "  ${YELLOW}Backup von ${CYAN}$DB_SELECTED${NC} ${YELLOW}läuft... Strg+C = Abbruch${NC}"
        START_TIME=$(date +%s)
        if command -v pv &>/dev/null; then
            mariadb-dump -u "$DB_USER" -p"$DB_PASS" --databases "$DB_SELECTED" | pv -p -s "$EST_SIZE" > "$BACKUP_FILE"
        else
            mariadb-dump -u "$DB_USER" -p"$DB_PASS" --databases "$DB_SELECTED" > "$BACKUP_FILE"
        fi
    fi

    END_TIME=$(date +%s)
    DURATION=$((END_TIME - START_TIME))
    RESULT_SIZE=$(numfmt --to=iec --format="%.1f" "$(stat -c%s "$BACKUP_FILE")" 2>/dev/null || echo "?")
    echo ""
    if [ $ABORT_FLAG -eq 1 ]; then
        echo -e "  ${YELLOW}${BOLD}⚠ Backup abgebrochen${NC}"
        ABORT_FLAG=0
        echo -e "\n  ${YELLOW}Enter für Menü...${NC}"
        read -r
        return
    fi

    echo -e "  ${GREEN}${BOLD}✓ Backup erstellt!${NC}"
    echo -e "  ${CYAN}  Datei:${NC} $BACKUP_FILE"
    echo -e "  ${CYAN}  Größe:${NC} $RESULT_SIZE"
    echo -e "  ${CYAN}  Dauer:${NC} $(printf '%02d:%02d' $((DURATION / 60)) $((DURATION % 60)))"
    echo ""
    echo -e "  ${YELLOW}Alte Backups ( >30 Tage) löschen?${NC}"

    if confirm_dialog; then
        find "$BACKUP_DIR" -name "mariadb-backup-*.sql" -mtime +30 -delete 2>/dev/null
        echo -e "  ${GREEN}✓ Alte Backups gelöscht${NC}"
    fi

    echo -e "\n  ${YELLOW}Enter für Menü...${NC}"
    read -r
}

do_restore() {
    print_header
    echo -e "${BOLD}${RED}  Backup wiederherstellen${NC}"
    echo "  ─────────────────────────────"
    echo ""
    echo -e "  ${YELLOW}ESC = zurück, Enter = auswählen${NC}"
    echo ""
    echo -e "  ${CYAN}Drücke Enter...${NC}"
    read -r

    if ! file_browser "$BACKUP_DIR"; then
        return
    fi

    print_header
    echo -e "${BOLD}${RED}  Backup wiederherstellen${NC}"
    echo "  ─────────────────────────────"
    echo ""
    echo -e "  ${RED}${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "  ${RED}${BOLD}║               ⚠  ACHTUNG  ⚠                ║${NC}"
    echo -e "  ${RED}${BOLD}║  Daten werden durch Backup ERSETZT!         ║${NC}"
    echo -e "  ${RED}${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "  ${CYAN}Datei:${NC} $SQL_FILE"
    FILE_SIZE=$(numfmt --to=iec --format="%.1f" "$(stat -c%s "$SQL_FILE")" 2>/dev/null || echo "?")
    echo -e "  ${CYAN}Größe:${NC} $FILE_SIZE"
    echo ""
    echo -e "  ${YELLOW}Wirklich wiederherstellen?${NC}"

    ABORT_FLAG=0
    if confirm_dialog; then
        print_header
        echo -e "  ${YELLOW}Wiederherstellung läuft... Strg+C = Abbruch${NC}"
        echo ""
        START_TIME=$(date +%s)
        if command -v pv &>/dev/null; then
            pv -p "$SQL_FILE" | mariadb -u "$DB_USER" -p"$DB_PASS"
        else
            mariadb -u "$DB_USER" -p"$DB_PASS" < "$SQL_FILE"
        fi
        END_TIME=$(date +%s)
        DURATION=$((END_TIME - START_TIME))
        echo ""
        if [ $ABORT_FLAG -eq 1 ]; then
            echo -e "  ${YELLOW}${BOLD}⚠ Wiederherstellung abgebrochen${NC}"
            ABORT_FLAG=0
        else
            echo -e "  ${GREEN}${BOLD}✓ Wiederherstellung abgeschlossen!${NC}"
            echo -e "  ${CYAN}  Dauer:${NC} $(printf '%02d:%02d' $((DURATION / 60)) $((DURATION % 60)))"
        fi
    else
        echo -e "\n  ${YELLOW}Wiederherstellung abgebrochen.${NC}"
    fi

    echo -e "\n  ${YELLOW}Enter für Menü...${NC}"
    read -r
}

do_list_backups() {
    print_header
    echo -e "${BOLD}${BLUE}  Alle Backups${NC}"
    echo "  ─────────────────────────────"
    echo ""

    local UP=$'\x1b[A'
    local DOWN=$'\x1b[B'
    local ESC=$'\x1b'
    local files=()
    while IFS= read -r -d '' f; do
        files+=("$f")
    done < <(find "$BACKUP_DIR" -maxdepth 1 -name '*.sql' -type f -print0 2>/dev/null | sort -z)

    if [ ${#files[@]} -eq 0 ]; then
        echo -e "  ${YELLOW}Keine Backups gefunden.${NC}"
    else
        local page=0
        local per_page=10

        while true; do
            print_header
            echo -e "${BOLD}${BLUE}  Alle Backups${NC}"
            echo "  ─────────────────────────────"
            echo -e "  ${YELLOW}Pfeile ↑↓ blättern, ESC zurück${NC}"
            echo ""

            start=$((page * per_page))
            end=$((start + per_page))
            [ $end -gt ${#files[@]} ] && end=${#files[@]}

            for i in $(seq $start $((end - 1))); do
                local f="${files[$i]}"
                local fname=$(basename "$f")
                local fsize=$(numfmt --to=iec --format="%.1f" "$(stat -c%s "$f")" 2>/dev/null)
                local fdate=$(stat -c%y "$f" 2>/dev/null | cut -d. -f1)
                echo -e "  ${fname}"
                echo -e "    ${CYAN}Größe:${NC} $fsize  ${CYAN}Datum:${NC} $fdate"
                echo ""
            done

            local total_pages=$(((${#files[@]} + per_page - 1) / per_page))
            echo -e "  ${YELLOW}Seite $((page + 1))/$total_pages  (${#files[@]} Backups)${NC}"

            local key
            key=$(read_key)
            case "$key" in
                "$UP") [ $page -gt 0 ] && page=$((page - 1)) ;;
                "$DOWN") [ $page -lt $((total_pages - 1)) ] && page=$((page + 1)) ;;
                ""|$'\n'|$'\r'|$ESC) break ;;
            esac
        done
    fi

    echo -e "\n  ${YELLOW}Enter für Menü...${NC}"
    read -r
}

if ! command -v mariadb &>/dev/null && ! command -v mysql &>/dev/null; then
    echo -e "${RED}✗ MariaDB/mysql nicht gefunden.${NC}"
    exit 1
fi

while true; do
    print_header
    print_info_bar

    menu_select "Hauptmenü" \
        "SQL-Datei importieren" \
        "Datenbank-Backup erstellen" \
        "Backup wiederherstellen" \
        "Alle Backups anzeigen" \
        "Beenden"

    choice=$?

    if [ $choice -eq 255 ]; then
        choice=4
    fi

    case $choice in
        0) do_import ;;
        1) do_backup ;;
        2) do_restore ;;
        3) do_list_backups ;;
        4)
            print_header
            echo -e "  ${GREEN}Bis bald!${NC}"
            echo ""
            exit 0
            ;;
    esac
done
