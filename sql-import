#!/usr/bin/env bash
set +e
# TESTTESTEST

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'
BOLD='\033[1m'
INV='\033[7m'

DB_USER="root"
DB_PASS="root"
BACKUP_DIR="$HOME/mariadb-backups"
mkdir -p "$BACKUP_DIR"

ABORT_FLAG=0
abort_handler() {
    ABORT_FLAG=1
    echo ""
    echo -e "  ${YELLOW}вҡ  Abbruch angefordert...${NC}"
}
trap abort_handler SIGINT

read_key() {
    local k
    IFS= read -r -s -n1 k 2>/dev/null
    if [[ $k == $'\x1b' ]]; then
        local rest
        IFS= read -r -s -n2 -t 0.1 rest 2>/dev/null
        k="${k}${rest}"
    fi
    printf '%s' "$k"
}

print_header() {
    printf '\033[2J\033[H'
    echo -e "${CYAN}${BOLD}в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ${NC}"
    echo -e "${CYAN}${BOLD}в”Ӯ       SMARTBOXX SQL TOOL  v1.1              в”Ӯ${NC}"
    echo -e "${CYAN}${BOLD}в”Ӯ          $(date '+%d.%m.%Y %H:%M')                   в”Ӯ${NC}"
    echo -e "${CYAN}${BOLD}в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ${NC}"
    echo ""
}

print_info_bar() {
    BACKUP_COUNT=$(find "$BACKUP_DIR" -maxdepth 1 -type f -name "*.sql" 2>/dev/null | wc -l)
    echo -e "  ${BOLD}User:${NC} ${GREEN}$DB_USER${NC}  ${BOLD}Backups:${NC} ${GREEN}$BACKUP_COUNT${NC}"
    if command -v pv &>/dev/null; then
        echo -e "  ${GREEN}вң“${NC} pv installiert"
    else
        echo -e "  ${YELLOW}вҡ ${NC} pv fehlt"
    fi
    echo ""
}

menu_select() {
    local title="$1"
    shift
    local items=("$@")
    local selected=0
    local UP=$'\x1b[A'
    local DOWN=$'\x1b[B'

    while true; do
        print_header
        echo -e "  ${BOLD}${BLUE}$title${NC}"
        echo "  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"
        echo ""

        for i in "${!items[@]}"; do
            if [ $i -eq $selected ]; then
                echo -e "  ${INV}${CYAN}  ${items[$i]}  ${NC}"
            else
                echo -e "  ${WHITE}  ${items[$i]}${NC}"
            fi
        done

        echo ""
        echo -e "  ${YELLOW}Pfeile вҶ‘вҶ“ bewegen, Enter wГӨhlen, ESC zurГјck${NC}"

        local key
        key=$(read_key)

        case "$key" in
            "$UP")
                selected=$((selected - 1))
                [ $selected -lt 0 ] && selected=$((${#items[@]} - 1))
                ;;
            "$DOWN")
                selected=$((selected + 1))
                [ $selected -ge ${#items[@]} ] && selected=0
                ;;
            ""|$'\n'|$'\r')
                return $selected
                ;;
            $'\x1b')
                return 255
                ;;
        esac
    done
}

file_browser() {
    local start_dir="${1:-$HOME}"
    local current_dir="$start_dir"
    local selected=0
    local UP=$'\x1b[A'
    local DOWN=$'\x1b[B'

    while true; do
        local items=()
        local types=()
        local dirs=()
        local files=()

        if [ "$current_dir" != "/" ]; then
            dirs+=("..")
        fi

        while IFS= read -r -d '' d; do
            local base
            base=$(basename "$d")
            dirs+=("$base")
        done < <(find "$current_dir" -maxdepth 1 -type d ! -name "$(basename "$current_dir")" -print0 2>/dev/null | sort -z)

        while IFS= read -r -d '' f; do
            local base
            base=$(basename "$f")
            files+=("$base")
        done < <(find "$current_dir" -maxdepth 1 -type f -name "*.sql" -print0 2>/dev/null | sort -z)

        for d in "${dirs[@]}"; do
            items+=("$d")
            types+=("dir")
        done
        for f in "${files[@]}"; do
            items+=("$f")
            types+=("file")
        done

        if [ $selected -ge ${#items[@]} ]; then
            selected=0
        fi

        while true; do
            print_header
            echo -e "${BOLD}${BLUE}  Datei-Auswahl${NC}"
            echo "  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"
            echo ""
            echo -e "  ${CYAN}$current_dir${NC}"
            echo ""

            if [ ${#items[@]} -eq 0 ]; then
                echo "  (leer)"
            else
                for i in "${!items[@]}"; do
                    local prefix="  "
                    local color="$WHITE"
                    local suffix=""
                    if [ $i -eq $selected ]; then
                        prefix="${INV} "
                        color="$CYAN"
                    fi
                    if [ "${types[$i]}" = "dir" ]; then
                        suffix="/"
                        [ $i -eq $selected ] && color="${CYAN}" || color="${GREEN}"
                    else
                        local fsize
                        fsize=$(numfmt --to=iec --format="%.1f" "$(stat -c%s "$current_dir/${items[$i]}" 2>/dev/null)" 2>/dev/null)
                        suffix="  ${YELLOW}(${fsize})${NC}"
                        [ $i -eq $selected ] && color="${CYAN}" || color="${YELLOW}"
                    fi
                    if [ $i -eq $selected ]; then
                        echo -e "${INV} ${color} ${items[$i]}${suffix}  ${NC}"
                    else
                        echo -e "  ${color} ${items[$i]}${suffix}${NC}"
                    fi
                done
            fi

            echo ""
            echo -e "  ${YELLOW}Pfeile вҶ‘вҶ“ bewegen, Enter wГӨhlen, ESC zurГјck${NC}"

            local key
            key=$(read_key)

            case "$key" in
                "$UP")
                    selected=$((selected - 1))
                    [ $selected -lt 0 ] && selected=$((${#items[@]} - 1))
                    ;;
                "$DOWN")
                    selected=$((selected + 1))
                    [ $selected -ge ${#items[@]} ] && selected=0
                    ;;
                ""|$'\n'|$'\r')
                    break
                    ;;
                $'\x1b')
                    return 1
                    ;;
            esac
        done

        if [ ${#items[@]} -eq 0 ]; then
            continue
        fi

        local idx=$selected
        local selected_item="${items[$idx]}"

        if [ "${types[$idx]}" = "dir" ]; then
            if [ "$selected_item" = ".." ]; then
                current_dir="$(dirname "$current_dir")"
            else
                current_dir="$current_dir/$selected_item"
            fi
            selected=0
        else
            SQL_FILE="$current_dir/$selected_item"
            return 0
        fi
    done
}

confirm_dialog() {
    local prompt="$1"
    local options=("JA" "NEIN")
    local selected=0
    local RIGHT=$'\x1b[C'
    local LEFT=$'\x1b[D'

    while true; do
        echo ""
        for i in "${!options[@]}"; do
            if [ $i -eq $selected ]; then
                echo -e "  ${INV}${RED}  ${options[$i]}  ${NC}"
            else
                echo -e "  ${WHITE}  ${options[$i]}${NC}"
            fi
        done
        echo ""
        echo -e "  ${YELLOW}вҶҗ вҶ’ wechseln, Enter bestГӨtigen${NC}"

        local key
        key=$(read_key)
        case "$key" in
            "$RIGHT") selected=1 ;;
            "$LEFT") selected=0 ;;
            ""|$'\n'|$'\r')
                [ $selected -eq 0 ] && return 0 || return 1
                ;;
        esac
    done
}

select_database() {
    local exclude_system="$1"
    local filter=""
    [ "$exclude_system" = "1" ] && filter="mysql|information_schema|performance_schema|sys"
    local dbs
    if [ -n "$filter" ]; then
        dbs=$(mariadb -u "$DB_USER" -p"$DB_PASS" -N -e "SHOW DATABASES;" 2>/dev/null | grep -v -E "^($filter)$" || true)
    else
        dbs=$(mariadb -u "$DB_USER" -p"$DB_PASS" -N -e "SHOW DATABASES;" 2>/dev/null || true)
    fi

    if [ -z "$dbs" ]; then
        echo -e "  ${RED}вң— Keine Datenbanken gefunden.${NC}"
        return 1
    fi

    local db_list=()
    while IFS= read -r db; do
        db_list+=("$db")
    done <<< "$dbs"

    menu_select "Datenbank auswГӨhlen:" "${db_list[@]}"
    local choice=$?
    [ $choice -eq 255 ] && return 1

    SELECTED_DB="${db_list[$choice]}"
    return 0
}

select_table() {
    local db="$1"
    local tables
    tables=$(mariadb -u "$DB_USER" -p"$DB_PASS" -N -e "SHOW TABLES FROM \`$db\`;" 2>/dev/null || true)

    if [ -z "$tables" ]; then
        echo -e "  ${RED}вң— Keine Tabellen in ${CYAN}$db${NC} gefunden.${NC}"
        return 1
    fi

    local tbl_list=()
    while IFS= read -r tbl; do
        tbl_list+=("$tbl")
    done <<< "$tables"

    menu_select "Tabelle in ${CYAN}$db${NC} auswГӨhlen:" "${tbl_list[@]}"
    local choice=$?
    [ $choice -eq 255 ] && return 1

    SELECTED_TABLE="${tbl_list[$choice]}"
    return 0
}

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ BACKUP в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

do_import() {
    print_header
    echo -e "${BOLD}${BLUE}  SQL-Datei importieren${NC}"
    echo "  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"
    echo ""
    echo -e "  ${YELLOW}ESC = zurГјck, Enter = Ordner Г¶ffnen/auswГӨhlen${NC}"
    echo ""
    echo -e "  ${CYAN}DrГјcke Enter...${NC}"
    read -r

    if ! file_browser "$HOME/SMARTBOXX-TOOLS"; then
        return
    fi

    FILE_SIZE=$(numfmt --to=iec --format="%.1f" "$(stat -c%s "$SQL_FILE")" 2>/dev/null || echo "?")
    echo -e "  ${GREEN}вң“ AusgewГӨhlt:${NC} $SQL_FILE"
    echo -e "  ${CYAN}  GrГ¶Гҹe:${NC} $FILE_SIZE"
    echo ""
    read -p "  Name der Zieldatenbank (leer = alle): " DB_NAME

    echo ""
    echo -e "  ${YELLOW}Import starten?${NC}"

    ABORT_FLAG=0
    if confirm_dialog; then
        print_header
        echo -e "  ${YELLOW}Import lГӨuft... Strg+C = Abbruch${NC}"
        echo ""

        START_TIME=$(date +%s)
        if [ -z "$DB_NAME" ]; then
            if command -v pv &>/dev/null; then
                pv -p "$SQL_FILE" | mariadb --force -u "$DB_USER" -p"$DB_PASS" 2>/dev/null
            else
                mariadb --force -u "$DB_USER" -p"$DB_PASS" < "$SQL_FILE" 2>/dev/null
            fi
        else
            mariadb -u "$DB_USER" -p"$DB_PASS" -e "CREATE DATABASE IF NOT EXISTS \`$DB_NAME\`;" 2>/dev/null
            if command -v pv &>/dev/null; then
                pv -p "$SQL_FILE" | mariadb --force -u "$DB_USER" -p"$DB_PASS" "$DB_NAME" 2>/dev/null
            else
                mariadb --force -u "$DB_USER" -p"$DB_PASS" "$DB_NAME" < "$SQL_FILE" 2>/dev/null
            fi
        fi

        END_TIME=$(date +%s)
        DURATION=$((END_TIME - START_TIME))
        echo ""
        if [ $ABORT_FLAG -eq 1 ]; then
            echo -e "  ${YELLOW}${BOLD}вҡ  Import abgebrochen${NC}"
            ABORT_FLAG=0
        else
            echo -e "  ${GREEN}${BOLD}вң“ Import abgeschlossen!${NC}"
            echo -e "  ${CYAN}  Dauer:${NC} $(printf '%02d:%02d' $((DURATION / 60)) $((DURATION % 60)))"
        fi
    else
        echo -e "\n  ${YELLOW}Import abgebrochen.${NC}"
    fi

    echo ""
    echo -e "  ${YELLOW}Enter fГјr MenГј...${NC}"
    read -r
}

do_backup_all() {
    local DBS
    DBS=$(mariadb -u "$DB_USER" -p"$DB_PASS" -N -e "SHOW DATABASES;" 2>/dev/null | grep -v -E "^(information_schema|performance_schema|sys)$" || true)

    if [ -z "$DBS" ]; then
        echo -e "\n  ${RED}вң— Keine Datenbanken gefunden.${NC}"
        echo -e "\n  ${YELLOW}Enter fГјr MenГј...${NC}"
        read -r; return
    fi

    local EST_SIZE
    EST_SIZE=$(mariadb -u "$DB_USER" -p"$DB_PASS" -NBe \
        "SELECT SUM(data_length + index_length) FROM information_schema.tables WHERE table_schema NOT IN ('mysql','information_schema','performance_schema','sys')" 2>/dev/null || echo 0)
    [ -z "$EST_SIZE" ] && EST_SIZE=0
    EST_SIZE=$((EST_SIZE * 2))

    TIMESTAMP=$(date '+%Y%m%d_%H%M%S')
    BACKUP_FILE="$BACKUP_DIR/mariadb-backup-alle-$TIMESTAMP.sql"

    echo -e "  ${YELLOW}Backup ALLER Datenbanken lГӨuft... Strg+C = Abbruch${NC}"
    START_TIME=$(date +%s)
    ABORT_FLAG=0
    if command -v pv &>/dev/null; then
        mariadb-dump -u "$DB_USER" -p"$DB_PASS" --hex-blob --databases $(echo "$DBS" | tr '\n' ' ') | pv -p -s "$EST_SIZE" > "$BACKUP_FILE"
    else
        mariadb-dump -u "$DB_USER" -p"$DB_PASS" --hex-blob --databases $(echo "$DBS" | tr '\n' ' ') > "$BACKUP_FILE"
    fi

    END_TIME=$(date +%s)
    DURATION=$((END_TIME - START_TIME))
    RESULT_SIZE=$(numfmt --to=iec --format="%.1f" "$(stat -c%s "$BACKUP_FILE")" 2>/dev/null || echo "?")
    echo ""
    if [ $ABORT_FLAG -eq 1 ]; then
        echo -e "  ${YELLOW}${BOLD}вҡ  Backup abgebrochen${NC}"
        ABORT_FLAG=0
        return
    fi
    echo -e "  ${GREEN}${BOLD}вң“ Backup erstellt!${NC}"
    echo -e "  ${CYAN}  Datei:${NC} $BACKUP_FILE"
    echo -e "  ${CYAN}  GrГ¶Гҹe:${NC} $RESULT_SIZE"
    echo -e "  ${CYAN}  Dauer:${NC} $(printf '%02d:%02d' $((DURATION / 60)) $((DURATION % 60)))"
}

do_backup_db() {
    if ! select_database 1; then
        echo -e "\n  ${YELLOW}Enter fГјr MenГј...${NC}"
        read -r; return
    fi
    local db="$SELECTED_DB"

    local EST_SIZE
    EST_SIZE=$(mariadb -u "$DB_USER" -p"$DB_PASS" -NBe \
        "SELECT SUM(data_length + index_length) FROM information_schema.tables WHERE table_schema='$db'" 2>/dev/null || echo 0)
    [ -z "$EST_SIZE" ] && EST_SIZE=0
    EST_SIZE=$((EST_SIZE * 2))

    TIMESTAMP=$(date '+%Y%m%d_%H%M%S')
    BACKUP_FILE="$BACKUP_DIR/mariadb-backup-${db}-$TIMESTAMP.sql"

    echo -e "  ${YELLOW}Backup von ${CYAN}$db${NC} ${YELLOW}lГӨuft... Strg+C = Abbruch${NC}"
    START_TIME=$(date +%s)
    ABORT_FLAG=0
    if command -v pv &>/dev/null; then
        mariadb-dump -u "$DB_USER" -p"$DB_PASS" --hex-blob --databases "$db" | pv -p -s "$EST_SIZE" > "$BACKUP_FILE"
    else
        mariadb-dump -u "$DB_USER" -p"$DB_PASS" --hex-blob --databases "$db" > "$BACKUP_FILE"
    fi

    END_TIME=$(date +%s)
    DURATION=$((END_TIME - START_TIME))
    RESULT_SIZE=$(numfmt --to=iec --format="%.1f" "$(stat -c%s "$BACKUP_FILE")" 2>/dev/null || echo "?")
    echo ""
    if [ $ABORT_FLAG -eq 1 ]; then
        echo -e "  ${YELLOW}${BOLD}вҡ  Backup abgebrochen${NC}"
        ABORT_FLAG=0
        return
    fi
    echo -e "  ${GREEN}${BOLD}вң“ Backup erstellt!${NC}"
    echo -e "  ${CYAN}  Datei:${NC} $BACKUP_FILE"
    echo -e "  ${CYAN}  GrГ¶Гҹe:${NC} $RESULT_SIZE"
    echo -e "  ${CYAN}  Dauer:${NC} $(printf '%02d:%02d' $((DURATION / 60)) $((DURATION % 60)))"
}

do_export_table() {
    if ! select_database 1; then
        echo -e "\n  ${YELLOW}Enter fГјr MenГј...${NC}"
        read -r; return
    fi
    local db="$SELECTED_DB"

    if ! select_table "$db"; then
        echo -e "\n  ${YELLOW}Enter fГјr MenГј...${NC}"
        read -r; return
    fi
    local tbl="$SELECTED_TABLE"

    TIMESTAMP=$(date '+%Y%m%d_%H%M%S')
    BACKUP_FILE="$BACKUP_DIR/${db}-${tbl}-$TIMESTAMP.sql"

    echo -e "  ${YELLOW}Exportiere ${CYAN}$db.$tbl${NC} ${YELLOW}...${NC}"
    START_TIME=$(date +%s)
    mariadb-dump -u "$DB_USER" -p"$DB_PASS" --hex-blob "$db" "$tbl" > "$BACKUP_FILE"
    END_TIME=$(date +%s)
    DURATION=$((END_TIME - START_TIME))
    RESULT_SIZE=$(numfmt --to=iec --format="%.1f" "$(stat -c%s "$BACKUP_FILE")" 2>/dev/null || echo "?")
    echo -e "  ${GREEN}${BOLD}вң“ Exportiert!${NC}"
    echo -e "  ${CYAN}  Datei:${NC} $BACKUP_FILE"
    echo -e "  ${CYAN}  GrГ¶Гҹe:${NC} $RESULT_SIZE"
    echo -e "  ${CYAN}  Dauer:${NC} $(printf '%02d:%02d' $((DURATION / 60)) $((DURATION % 60)))"
}

